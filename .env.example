# ── Telegram ──────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
AUTHORIZED_USER_ID=123456789

# ── Daftra ────────────────────────────────────────────────────
# Your Daftra API key (Settings → API → API Key)
DAFTRA_API_KEY=your_daftra_api_key_here

# Your Daftra subdomain (e.g. if your URL is revive.daftra.com → use "revive")
DAFTRA_SUBDOMAIN=revive

# ── Schedule ──────────────────────────────────────────────────
# Morning summary time (24h format)
MORNING_SUMMARY_HOUR=8
MORNING_SUMMARY_MINUTE=0

# Timezone (e.g. Asia/Riyadh, Africa/Cairo, Asia/Dubai)
TIMEZONE=Asia/Riyadh

# How often to check for out-of-stock products (in hours)
LOW_STOCK_CHECK_INTERVAL_HOURS=6
